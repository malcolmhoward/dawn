# DAWN install.conf — Unattended installation configuration
#
# Usage: ./scripts/install.sh --config scripts/install.conf.example
#
# This file is sourced as a shell script. Only KEY=VALUE assignments are allowed.
# If this file contains API keys, restrict permissions: chmod 600 install.conf
#

# Install target: "server" (default) or "satellite"
INSTALL_TARGET="server"

# LLM provider(s), comma-separated. First = default.
# Options: openai, claude, gemini, local
LLM_PROVIDER="claude"

# Whisper ASR model: tiny, base, small
WHISPER_MODEL="base"

# Build preset: default, local, debug, server, full
BUILD_PRESET="default"

# Optional features, comma-separated or "all"
# Options: ssl, mqtt, searxng, flaresolverr, plex, homeassistant
FEATURES="ssl,mqtt"

# API keys — uncomment and fill in, or add to secrets.toml after install
# OPENAI_KEY=""
# CLAUDE_KEY=""
# GEMINI_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Satellite-specific keys (used only when INSTALL_TARGET="satellite").
# Overrides the interactive prompts in present_satellite_choices().
# ─────────────────────────────────────────────────────────────────────────────

# Daemon connection
# SAT_SERVER_HOST="192.168.1.100"
# SAT_SERVER_PORT="3000"
# SAT_SSL="true"
# SAT_SSL_VERIFY="true"

# Identity — must be unique per satellite
# SAT_NAME="Kitchen"
# SAT_LOCATION="kitchen"

# ASR engine: "vosk" (streaming, recommended on Pi) or "whisper" (batch)
# SAT_ASR_ENGINE="vosk"

# Vosk model (used when SAT_ASR_ENGINE="vosk"): "small" or "large"
# SAT_VOSK_MODEL="small"

# Whisper model (used when SAT_ASR_ENGINE="whisper"): "tiny-q5_1" or "base"
# SAT_WHISPER_MODEL="tiny-q5_1"

# Optional features
# SAT_ENABLE_SDL_UI="false"   # Set to "true" for touchscreen UI (needs attached display)
# SAT_ENABLE_OPUS="true"      # Music streaming — on by default. Set to "false" only if
                              # you're sure you don't want it; the dep (libopus-dev) is tiny.

# ALSA devices — run `arecord -l` / `aplay -l` on the Pi to find these
# SAT_CAPTURE_DEVICE="plughw:1,0"
# SAT_PLAYBACK_DEVICE="plughw:1,0"

# Registration key (optional) — matches the key generated on the daemon via
# `./generate_ssl_cert.sh --gen-key`. Leave unset if the daemon has no key.
# Treat as a secret; do not commit a filled-in value to version control.
# SAT_REGISTRATION_KEY=""
