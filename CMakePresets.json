{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Full)",
      "description": "Full build with all features enabled (alias for 'full')",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_WEBUI": "ON"
      }
    },
    {
      "name": "local",
      "displayName": "Local Only",
      "description": "Local microphone only, no network features (embedded / standalone)",
      "binaryDir": "${sourceDir}/build-local",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_WEBUI": "OFF"
      }
    },
    {
      "name": "full",
      "displayName": "Full",
      "description": "All features enabled: local + WebUI + DAP2 satellites",
      "binaryDir": "${sourceDir}/build-full",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_WEBUI": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Full)",
      "description": "Full build with debug symbols",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_WEBUI": "ON"
      }
    },
    {
      "name": "server",
      "displayName": "Server",
      "description": "Cloud/server deployment: WebUI + satellites, no local audio required",
      "binaryDir": "${sourceDir}/build-server",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_WEBUI": "ON",
        "SERVER_ONLY": "ON",
        "ENABLE_AEC": "OFF"
      }
    },
    {
      "name": "server-debug",
      "displayName": "Server (Debug)",
      "description": "Server deployment with debug symbols",
      "binaryDir": "${sourceDir}/build-server-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_WEBUI": "ON",
        "SERVER_ONLY": "ON",
        "ENABLE_AEC": "OFF"
      }
    },
    {
      "name": "ci",
      "displayName": "CI (Unit Tests Only)",
      "description": "Minimal build for CI: unit tests without ONNX, CUDA, WebUI, or hardware deps. VOSK=ON skips the whisper.cpp submodule.",
      "binaryDir": "${sourceDir}/build-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_WEBUI": "OFF",
        "ENABLE_TUI": "OFF",
        "ENABLE_AEC": "OFF",
        "ENABLE_VOSK": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "local",
      "configurePreset": "local"
    },
    {
      "name": "full",
      "configurePreset": "full"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "server",
      "configurePreset": "server"
    },
    {
      "name": "server-debug",
      "configurePreset": "server-debug"
    },
    {
      "name": "ci",
      "configurePreset": "ci"
    }
  ]
}
